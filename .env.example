# FastAPI backend URL (Cloud Run deployment URL)
API_URL=https://your-backend-service.run.app

# JWT secret (must match the backend JWT_SECRET)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# Anthropic API key for AI chatbot (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
